# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Porta onde o bot escuta (painel do QR code)
PORT=3000

# Chave do Google Gemini (gratis em https://aistudio.google.com/app/apikey)
# Sem essa chave o bot funciona normalmente, mas sem as funcoes de IA (NPC, resumo, fofoca)
GEMINI_API_KEY=
