# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# URL onde a Evolution API está rodando
# Local:  http://localhost:8082
# Nuvem:  https://sua-evolution.railway.app
EVOLUTION_URL=http://localhost:8082

# Chave de autenticação da Evolution API
# Deve ser a mesma definida em AUTHENTICATION_API_KEY no docker-compose.yml
EVOLUTION_API_KEY=coloque-uma-chave-secreta-aqui

# Nome da instância do WhatsApp criada na Evolution
INSTANCE_NAME=bot-voz

# Porta onde o bot vai escutar os webhooks
PORT=3000
