{
  "buildCommand": "cd web3d && npm install",
  "outputDirectory": "web3d",
  "rewrites": [
    {
      "source": "/advanced",
      "destination": "/advanced.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
